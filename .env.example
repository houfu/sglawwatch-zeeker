# Environment Variables for sglawwatch-zeeker
# Copy this file to .env and fill in your actual values
# Note: .env is already in .gitignore to keep secrets safe

# ============================================
# API Keys for Headlines Resource
# ============================================

# Jina Reader API - for extracting article content from web pages
# Get your free API key at: https://jina.ai/reader/
JINA_API_TOKEN=your_jina_api_token_here

# LLM Server - for generating article summaries
# Any OpenAI-compatible API: local (Ollama, vLLM, LM Studio)
# or cloud (OpenAI, Groq, Together, Anthropic-compatible proxies)
#
# For local Ollama on Tailscale (recommended):
LLM_BASE_URL=http://houfus-macbook-pro:11434/v1
LLM_API_KEY=ollama
LLM_MODEL=gemma4:26b
# TAILSCALE_PROXY is set automatically by NanoClaw when Tailscale sidecar is active.
# No need to set it manually — it routes LLM calls to Ollama through the Tailscale network.
#
# For cloud OpenAI (fallback):
# LLM_BASE_URL=https://api.openai.com/v1
# LLM_API_KEY=your_openai_key_here
# LLM_MODEL=gpt-4.1-mini

# ============================================
# S3 Configuration for Zeeker Deployment
# ============================================

# S3 bucket name where your database will be deployed
# Required for: uv run zeeker deploy
S3_BUCKET=your-bucket-name

# AWS credentials for S3 access
# Get these from AWS IAM or your S3-compatible service
AWS_ACCESS_KEY_ID=your_aws_access_key
AWS_SECRET_ACCESS_KEY=your_aws_secret_key

# S3 endpoint URL (optional)
# Only needed for non-AWS S3 services like Contabo, DigitalOcean Spaces, etc.
# For AWS S3, leave this blank or remove the line
# S3_ENDPOINT_URL=https://your-s3-endpoint.com

# ============================================
# Usage Notes
# ============================================

# For production/testing environments:
# - Load this .env file manually when needed
# - Use: python -c "from dotenv import load_dotenv; load_dotenv()"
# - Or export variables to shell environment

# For basic testing (recommended):
# - Tests work WITHOUT real API keys (they use mocks)
# - Just run: uv run pytest test_headlines.py

# For integration testing with real APIs:
# - Load environment variables manually or export to shell
# - This will test actual API integrations
# - Note: This will use your API quotas/credits

# For S3 deployment:
# - Ensure all S3_* and AWS_* variables are set in environment
# - Run: uv run zeeker deploy